rowwidth\":1},\"geo\":{\"bgcolor\":\"white\",\"landcolor\":\"#E5ECF6\",\"subunitcolor\":\"white\",\"showland\":true,\"showlakes\":true,\"lakecolor\":\"white\"},\"title\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"}}}},                        {\"responsive\": true}                    ).then(function(){\n                            \nvar gd = document.getElementById('c11cbc25-2e5d-4a1d-a97a-5dccbf8fa4c1');\nvar x = new MutationObserver(function (mutations, observer) {{\n        var display = window.getComputedStyle(gd).display;\n        if (!display || display === 'none') {{\n            console.log([gd, 'removed!']);\n            Plotly.purge(gd);\n            observer.disconnect();\n        }}\n}});\n\n// Listen for the removal of the full notebook cells\nvar notebookContainer = gd.closest('#notebook-container');\nif (notebookContainer) {{\n    x.observe(notebookContainer, {childList: true});\n}}\n\n// Listen for the clearing of the current output cell\nvar outputEl = gd.closest('.output');\nif (outputEl) {{\n    x.observe(outputEl, {childList: true});\n}}\n\n                        })                };                            </script>        </div>\n</body>\n</html>"},"metadata":{}}],"execution_count":71},{"cell_type":"code","source":"from pathlib import Path\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\n\nfrom sklearn.model_selection import ParameterGrid\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.impute import SimpleImputer\nfrom sklearn.preprocessing import OneHotEncoder, StandardScaler\nfrom sklearn.feature_extraction.text import TfidfVectorizer\nfrom sklearn.decomposition import TruncatedSVD, PCA\nfrom sklearn.linear_model import Ridge\nfrom sklearn.ensemble import RandomForestRegressor\nfrom sklearn.dummy import DummyRegressor\nfrom sklearn.metrics import (\n    mean_absolute_error,\n    mean_squared_error,\n    median_absolute_error,\n    r2_score,\n)\n\nfrom src.data.cleaner import clean_target\n\nSEED = 42\nrng = np.random.default_rng(SEED)\n\nif \"LISTINGS_PATH\" not in globals() or not Path(LISTINGS_PATH).is_file():\n    candidates = [\n        path for path in Path(\"/kaggle/input\").rglob(\"*\")\n        if path.is_file()\n        and \"listing\" in path.name.lower()\n        and path.name.lower().endswith((\".csv\", \".csv.gz\"))\n    ]\n    if not candidates:\n        raise FileNotFoundError(\"No listings CSV file found under /kaggle/input.\")\n    LISTINGS_PATH = max(candidates, key=lambda p: p.stat().st_size)\n\nprint(\"Using listings file:\", LISTINGS_PATH)\n\ndf_mm = pd.read_csv(LISTINGS_PATH, low_memory=False)\ndf_mm = clean_target(df_mm).reset_index(drop=True)\n\nif len(df_mm) == 0:\n    raise ValueError(\"The cleaned listings dataset has no rows.\")\n\n# Convert percentage strings such as '95%' to 0.95.\ndef parse_percent(series):\n    return (\n        series.astype(str)\n        .str.replace(\"%\", \"\", regex=False)\n        .replace({\"nan\": np.nan, \"None\": np.nan})\n        .astype(float)\n        / 100.0\n    )\n\nfor column in [\"host_response_rate\", \"host_acceptance_rate\"]:\n    if column in df_mm.columns:\n        df_mm[column] = parse_percent(df_mm[column])\n\n# Some Inside Airbnb files store bathrooms only as text.\nif \"bathrooms\" not in df_mm.columns and \"bathrooms_text\" in df_mm.columns:\n    df_mm[\"bathrooms\"] = pd.to_numeric(\n        df_mm[\"bathrooms_text\"].astype(str).str.extract(r\"([0-9]+(?:\\.[0-9]+)?)\")[0],\n        errors=\"coerce\",\n    )\n\n# Leakage-safe derived features: none of these uses the target price.\nif \"amenities\" in df_mm.columns:\n    df_mm[\"amenities_count\"] = df_mm[\"amenities\"].fillna(\"\").astype(str).str.count(\",\") + 1\n    df_mm.loc[df_mm[\"amenities\"].fillna(\"\").eq(\"\"), \"amenities_count\"] = 0\n\nif {\"accommodates\", \"bedrooms\"}.issubset(df_mm.columns):\n    df_mm[\"guests_per_bedroom\"] = (\n        pd.to_numeric(df_mm[\"accommodates\"], errors=\"coerce\")\n        / pd.to_numeric(df_mm[\"bedrooms\"], errors=\"coerce\").replace(0, np.nan)\n    )\n\nif {\"beds\", \"accommodates\"}.issubset(df_mm.columns):\n    df_mm[\"beds_per_guest\"] = (\n        pd.to_numeric(df_mm[\"beds\"], errors=\"coerce\")\n        / pd.to_numeric(df_mm[\"accommodates\"], errors=\"coerce\").replace(0, np.nan)\n    )\n\nif {\"bathrooms\", \"accommodates\"}.issubset(df_mm.columns):\n    df_mm[\"bathrooms_per_guest\"] = (\n        pd.to_numeric(df_mm[\"bathrooms\"], errors=\"coerce\")\n        / pd.to_numeric(df_mm[\"accommodates\"], errors=\"coerce\").replace(0, np.nan)\n    )\n\nnumeric_candidates = [\n    \"accommodates\", \"bedrooms\", \"beds\", \"bathrooms\",\n    \"minimum_nights\", \"maximum_nights\", \"number_of_reviews\",\n    \"reviews_per_month\", \"review_scores_rating\",\n    \"review_scores_accuracy\", \"review_scores_cleanliness\",\n    \"review_scores_checkin\", \"review_scores_communication\",\n    \"review_scores_location\", \"review_scores_value\",\n    \"calculated_host_listings_count\", \"availability_30\",\n    \"availability_60\", \"availability_90\", \"availability_365\",\n    \"host_response_rate\", \"host_acceptance_rate\", \"amenities_count\",\n    \"guests_per_bedroom\", \"beds_per_guest\", \"bathrooms_per_guest\",\n]\n\ncategorical_candidates = [\n    \"room_type\", \"property_type\", \"neighbourhood_cleansed\",\n    \"host_is_superhost\", \"instant_bookable\",\n]\n\ntext_candidates = [\n    \"name\", \"description\", \"neighborhood_overview\", \"host_about\", \"amenities\",\n]\n\nnumeric_cols = [c for c in numeric_candidates if c in df_mm.columns and df_mm[c].notna().any()]\ncategorical_cols = [c for c in categorical_candidates if c in df_mm.columns and df_mm[c].notna().any()]\ntext_cols = [c for c in text_candidates if c in df_mm.columns]\n\nif not {\"latitude\", \"longitude\"}.issubset(df_mm.columns):\n    raise ValueError(\"latitude and longitude are required for the spatial modality.\")\n\ny_all = df_mm[\"price\"].to_numpy(dtype=np.float32)\n\nindices = rng.permutation(len(df_mm))\ntrain_end = int(0.70 * len(indices))\nval_end = int(0.85 * len(indices))\n\ntrain_idx = indices[:train_end]\nval_idx = indices[train_end:val_end]\ntest_idx = indices[val_end:]\n\ny_train = y_all[train_idx]\ny_val = y_all[val_idx]\ny_test = y_all[test_idx]\n\nprint(f\"Rows: {len(df_mm)} | train={len(train_idx)}, val={len(val_idx)}, test={len(test_idx)}\")\nprint(\"Numeric columns:\", len(numeric_cols))\nprint(\"Categorical columns:\", len(categorical_cols))\nprint(\"Text columns:\", text_cols)\n\n# BLOCK 2\nnumeric_pipe = Pipeline([\n    (\"imputer\", SimpleImputer(strategy=\"median\")),\n    (\"scaler\", StandardScaler()),\n])\n\ntry:\n    one_hot = OneHotEncoder(\n        handle_unknown=\"ignore\",\n        min_frequency=3,\n        sparse_output=False,\n    )\nexcept TypeError:\n    one_hot = OneHotEncoder(\n        handle_unknown=\"ignore\",\n        min_frequency=3,\n        sparse=False,\n    )\n\ncategorical_pipe = Pipeline([\n    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n    (\"onehot\", one_hot),\n])\n\ntabular_processor = ColumnTransformer([\n    (\"numeric\", numeric_pipe, numeric_cols),\n    (\"categorical\", categorical_pipe, categorical_cols),\n], remainder=\"drop\")\n\nX_train_tab = tabular_processor.fit_transform(df_mm.iloc[train_idx]).astype(np.float32)\nX_val_tab = tabular_processor.transform(df_mm.iloc[val_idx]).astype(np.float32)\nX_test_tab = tabular_processor.transform(df_mm.iloc[test_idx]).astype(np.float32)\n\ntabular_feature_names = tabular_processor.get_feature_names_out().tolist()\n\n# Spatial features are fitted only from the training coordinates.\nlat = pd.to_numeric(df_mm[\"latitude\"], errors=\"coerce\").to_numpy(dtype=float)\nlon = pd.to_numeric(df_mm[\"longitude\"], errors=\"coerce\").to_numpy(dtype=float)\n\nlat_median = np.nanmedian(lat[train_idx])\nlon_median = np.nanmedian(lon[train_idx])\nlat = np.where(np.isfinite(lat), lat, lat_median)\nlon = np.where(np.isfinite(lon), lon, lon_median)\n\ncenter_lat = lat[train_idx].mean()\ncenter_lon = lon[train_idx].mean()\n\ndef haversine_km(lat_values, lon_values, ref_lat, ref_lon):\n    earth_radius = 6371.0\n    lat1 = np.radians(lat_values)\n    lon1 = np.radians(lon_values)\n    lat2 = np.radians(ref_lat)\n    lon2 = np.radians(ref_lon)\n    dlat = lat1 - lat2\n    dlon = lon1 - lon2\n    a = np.sin(dlat / 2) ** 2 + np.cos(lat1) * np.cos(lat2) * np.sin(dlon / 2) ** 2\n    return 2 * earth_radius * np.arcsin(np.sqrt(a))\n\ndistance = haversine_km(lat, lon, center_lat, center_lon)\nX_spatial_all = np.column_stack([\n    lat,\n    lon,\n    distance,\n    lat ** 2,\n    lon ** 2,\n    lat * lon,\n])\n\nspatial_feature_names = [\n    \"latitude\", \"longitude\", \"distance_to_training_center_km\",\n    \"latitude_squared\", \"longitude_squared\", \"latitude_longitude_interaction\",\n]\n\nspatial_scaler = StandardScaler()\nX_train_spatial = spatial_scaler.fit_transform(X_spatial_all[train_idx]).astype(np.float32)\nX_val_spatial = spatial_scaler.transform(X_spatial_all[val_idx]).astype(np.float32)\nX_test_spatial = spatial_scaler.transform(X_spatial_all[test_idx]).astype(np.float32)\n\nprint(\"Tabular shape:\", X_train_tab.shape)\nprint(\"Spatial shape:\", X_train_spatial.shape)\n\n# BLOCK 3\ncombined_text = (\n    df_mm[text_cols]\n    .fillna(\"\")\n    .astype(str)\n    .agg(\" \".join, axis=1)\n)\n\ntfidf = TfidfVectorizer(\n    max_features=8000,\n    ngram_range=(1, 2),\n    min_df=3,\n    max_df=0.95,\n    stop_words=\"english\",\n    sublinear_tf=True,\n)\n\nX_train_tfidf = tfidf.fit_transform(combined_text.iloc[train_idx])\nX_val_tfidf = tfidf.transform(combined_text.iloc[val_idx])\nX_test_tfidf = tfidf.transform(combined_text.iloc[test_idx])\n\nn_text_components = min(64, X_train_tfidf.shape[0] - 1, X_train_tfidf.shape[1] - 1)\nif n_text_components < 2:\n    raise ValueError(\"Not enough usable text to create text features.\")\n\ntext_svd = TruncatedSVD(n_components=n_text_components, random_state=SEED)\nX_train_text = text_svd.fit_transform(X_train_tfidf)\nX_val_text = text_svd.transform(X_val_tfidf)\nX_test_text = text_svd.transform(X_test_tfidf)\n\ntext_scaler = StandardScaler()\nX_train_text = text_scaler.fit_transform(X_train_text).astype(np.float32)\nX_val_text = text_scaler.transform(X_val_text).astype(np.float32)\nX_test_text = text_scaler.transform(X_test_text).astype(np.float32)\n\ntext_feature_names = [f\"text_svd_{i+1}\" for i in range(X_train_text.shape[1])]\n\nprint(\"TF-IDF vocabulary size:\", len(tfidf.vocabulary_))\nprint(\"Compressed text shape:\", X_train_text.shape)\nprint(\"Explained text variance:\", round(text_svd.explained_variance_ratio_.sum(), 4))\n\n# BLOCK 4\nuse_image_features = False\nX_train_image = X_val_image = X_test_image = None\nimage_feature_names = []\n\nif \"X_images_50\" in globals() and X_images_50 is not None:\n    image_array = np.asarray(X_images_50, dtype=np.float32)\n\n    if len(image_array) == len(df_mm):\n        image_array = np.nan_to_num(image_array, nan=0.0, posinf=0.0, neginf=0.0)\n        nonzero_rows = np.any(image_array != 0, axis=1)\n        success_rate = nonzero_rows.mean()\n        print(f\"Usable image rows: {success_rate:.1%}\")\n\n        if success_rate >= 0.10:\n            n_image_components = min(64, image_array.shape[1], len(train_idx) - 1)\n            image_pca = PCA(\n                n_components=n_image_components,\n                svd_solver=\"randomized\",\n                random_state=SEED,\n            )\n\n            X_train_image = image_pca.fit_transform(image_array[train_idx])\n            X_val_image = image_pca.transform(image_array[val_idx])\n            X_test_image = image_pca.transform(image_array[test_idx])\n\n            image_scaler = StandardScaler()\n            X_train_image = image_scaler.fit_transform(X_train_image).astype(np.float32)\n            X_val_image = image_scaler.transform(X_val_image).astype(np.float32)\n            X_test_image = image_scaler.transform(X_test_image).astype(np.float32)\n\n            image_feature_names = [f\"image_pca_{i+1}\" for i in range(n_image_components)]\n            use_image_features = True\n        else:\n            print(\"Image features are mostly zero, so they are excluded.\")\n    else:\n        print(\n            \"Image features are excluded because their row count does not match the cleaned listings:\",\n            image_array.shape[0], \"!=\", len(df_mm)\n        )\nelse:\n    print(\"X_images_50 was not found. The models will run without images.\")\n\nX_train_tab_spatial = np.hstack([X_train_tab, X_train_spatial]).astype(np.float32)\nX_val_tab_spatial = np.hstack([X_val_tab, X_val_spatial]).astype(np.float32)\nX_test_tab_spatial = np.hstack([X_test_tab, X_test_spatial]).astype(np.float32)\n\nX_train_tab_spatial_text = np.hstack([X_train_tab_spatial, X_train_text]).astype(np.float32)\nX_val_tab_spatial_text = np.hstack([X_val_tab_spatial, X_val_text]).astype(np.float32)\nX_test_tab_spatial_text = np.hstack([X_test_tab_spatial, X_test_text]).astype(np.float32)\n\nmodalities = {\n    \"Tabular + spatial\": (\n        X_train_tab_spatial,\n        X_val_tab_spatial,\n        X_test_tab_spatial,\n        tabular_feature_names + spatial_feature_names,\n    ),\n    \"Text only\": (\n        X_train_text,\n        X_val_text,\n        X_test_text,\n        text_feature_names,\n    ),\n    \"Tabular + spatial + text\": (\n        X_train_tab_spatial_text,\n        X_val_tab_spatial_text,\n        X_test_tab_spatial_text,\n        tabular_feature_names + spatial_feature_names + text_feature_names,\n    ),\n}\n\nif use_image_features:\n    X_train_all = np.hstack([X_train_tab_spatial_text, X_train_image]).astype(np.float32)\n    X_val_all = np.hstack([X_val_tab_spatial_text, X_val_image]).astype(np.float32)\n    X_test_all = np.hstack([X_test_tab_spatial_text, X_test_image]).astype(np.float32)\n\n    modalities[\"Tabular + spatial + text + image\"] = (\n        X_train_all,\n        X_val_all,\n        X_test_all,\n        tabular_feature_names + spatial_feature_names + text_feature_names + image_feature_names,\n    )\n\nfor name, (Xtr, Xv, Xte, _) in modalities.items():\n    print(name, Xtr.shape, Xv.shape, Xte.shape)\n\n# BLOCK 5\nresults = []\npredictions = {}\nmodels_fitted = {}\n\n\ndef clip_price(predictions_array):\n    return np.clip(np.asarray(predictions_array, dtype=float), 10.0, None)\n\n\ndef regression_metrics(y_true, y_pred):\n    y_true = np.asarray(y_true, dtype=float)\n    y_pred = clip_price(y_pred)\n    absolute_percentage_error = np.abs((y_true - y_pred) / y_true) * 100.0\n\n    return {\n        \"MAE (€)\": mean_absolute_error(y_true, y_pred),\n        \"RMSE (€)\": mean_squared_error(y_true, y_pred) ** 0.5,\n        \"Median AE (€)\": median_absolute_error(y_true, y_pred),\n        \"MAPE (%)\": absolute_percentage_error.mean(),\n        \"Median APE (%)\": np.median(absolute_percentage_error),\n        \"R²\": r2_score(y_true, y_pred),\n        \"Relative MAE (%)\": mean_absolute_error(y_true, y_pred) / y_true.mean() * 100.0,\n        \"Within 20% (%)\": (absolute_percentage_error <= 20.0).mean() * 100.0,\n    }\n\n\ndef save_result(model_name, modality_name, val_pred, test_pred, model):\n    val_pred = clip_price(val_pred)\n    test_pred = clip_price(test_pred)\n\n    val_values = regression_metrics(y_val, val_pred)\n    test_values = regression_metrics(y_test, test_pred)\n\n    row = {\"Model\": model_name, \"Modality\": modality_name}\n    row.update({f\"Val {key}\": value for key, value in val_values.items()})\n    row.update({f\"Test {key}\": value for key, value in test_values.items()})\n\n    results.append(row)\n    predictions[model_name] = test_pred\n    models_fitted[model_name] = model\n\n\n# Median baseline\nbaseline = DummyRegressor(strategy=\"median\")\nbaseline.fit(np.zeros((len(y_train), 1)), y_train)\nsave_result(\n    \"Median baseline\",\n    \"Target only\",\n    baseline.predict(np.zeros((len(y_val), 1))),\n    baseline.predict(np.zeros((len(y_test), 1))),\n    baseline,\n)\n\nprint(\"Metric functions and baseline are ready.\")\n\n# BLOCK 6\nridge_alphas = [0.01, 0.1, 1.0, 10.0, 100.0, 1000.0]\nridge_tuning_rows = []\n\nfor modality_name, (Xtr, Xv, Xte, _) in modalities.items():\n    best = None\n\n    for alpha in ridge_alphas:\n        model = Ridge(\n            alpha=alpha,\n            solver=\"lsqr\",\n            max_iter=10000,\n            tol=1e-4,\n        )\n        model.fit(Xtr, y_train)\n\n        val_pred = clip_price(model.predict(Xv))\n        val_metrics = regression_metrics(y_val, val_pred)\n\n        ridge_tuning_rows.append({\n            \"Modality\": modality_name,\n            \"Alpha\": alpha,\n            \"Validation RMSE (€)\": val_metrics[\"RMSE (€)\"],\n            \"Validation MAE (€)\": val_metrics[\"MAE (€)\"],\n            \"Validation MAPE (%)\": val_metrics[\"MAPE (%)\"],\n        })\n\n        if best is None or val_metrics[\"RMSE (€)\"] < best[0]:\n            best = (val_metrics[\"RMSE (€)\"], alpha, model, val_pred)\n\n    _, best_alpha, best_model, best_val_pred = best\n    test_pred = best_model.predict(Xte)\n\n    save_result(\n        f\"Ridge alpha={best_alpha:g} [{modality_name}]\",\n        modality_name,\n        best_val_pred,\n        test_pred,\n        best_model,\n    )\n\n    print(f\"Ridge | {modality_name} | best alpha={best_alpha:g}\")\n\nridge_tuning_df = pd.DataFrame(ridge_tuning_rows)\ndisplay(ridge_tuning_df.round(3))\n\nfor modality_name in ridge_tuning_df[\"Modality\"].unique():\n    plot_df = ridge_tuning_df[ridge_tuning_df[\"Modality\"] == modality_name].sort_values(\"Alpha\")\n\n    plt.figure(figsize=(7, 4))\n    plt.plot(plot_df[\"Alpha\"], plot_df[\"Validation RMSE (€)\"], marker=\"o\")\n    plt.xscale(\"log\")\n    plt.xlabel(\"Ridge alpha\")\n    plt.ylabel(\"Validation RMSE (€)\")\n    plt.title(f\"Ridge tuning: {modality_name}\")\n